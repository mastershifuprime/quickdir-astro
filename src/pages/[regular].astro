---
import Base from "@/layouts/Base.astro";
import MDXContent from "@/layouts/helpers/MDXContent";
import { getSinglePage } from "@/lib/contentParser";
import PageHeader from "@/layouts/partials/PageHeader";
import type { RegularPage } from "@/types";

const { regular } = Astro.params;
const regularData = getSinglePage("pages");
const data = regularData.find((page: RegularPage) => page.slug === regular);

if (!data) {
  return Astro.redirect("/404");
}

const { frontmatter, content } = data;
const { title, meta_title, description, image } = frontmatter;

export function getStaticPaths() {
  const pages = getSinglePage("pages");
  return pages.map((page: any) => ({
    params: { regular: page.slug },
  }));
}
---

<Base {title} {meta_title} {description} {image}>
  <PageHeader {title} {description} />
  <section class="section">
    <div class="container">
      <div class="row">
        <div class="col-10 mx-auto">
          <div class="content">
            <MDXContent {content} client:load />
          </div>
        </div>
      </div>
    </div>
  </section>
</Base>
