---
import config from "@/config/config.json";
import { plainify } from "@/lib/utils/textConverter";
import "@/styles/main.css";
import { ClientRouter } from "astro:transitions";
import Footer from "@/partials/Footer";
import Header from "@/partials/Header";
import SearchModal from "@/components/SearchModal";
import ScrollToTop from "@/components/ScrollToTop";
import ToasterWrapper from "@/components/ToasterWrapper";

export interface Props {
  title?: string;
  meta_title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  canonical?: string;
}

const { title, meta_title, description, image, noindex, canonical } =
  Astro.props;
---

<!doctype html>
<html lang="en" class="text-base">
  <head>
    <meta charset="UTF-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, maximum-scale=5"
    />
    <!-- favicon -->
    <link rel="shortcut icon" href={config.site.favicon} />
    <!-- theme meta -->
    <meta name="theme-name" content="quickdir-astro" />
    <meta name="msapplication-TileColor" content="#000000" />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: light)"
      content="#fff"
    />
    <meta
      name="theme-color"
      media="(prefers-color-scheme: dark)"
      content="#000"
    />
    <meta name="generator" content={Astro.generator} />

    <!-- title -->
    <title>
      {plainify(meta_title ? meta_title : title ? title : config.site.title)}
    </title>

    <!-- canonical url -->
    {canonical && <link rel="canonical" href={canonical} />}

    <!-- noindex robots -->
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <!-- meta-description -->
    <meta
      name="description"
      content={plainify(
        description ? description : config.metadata.meta_description,
      )}
    />

    <ClientRouter />

    <!-- author -->
    <meta name="author" content={config.metadata.meta_author} />

    <!-- og tags -->
    <meta
      property="og:title"
      content={plainify(
        meta_title ? meta_title : title ? title : config.site.title,
      )}
    />
    <meta
      property="og:description"
      content={plainify(
        description ? description : config.metadata.meta_description,
      )}
    />
    <meta property="og:type" content="website" />
    <meta
      property="og:url"
      content={`${config.site.base_url}/${Astro.url.pathname.replace("/", "")}`}
    />
    <meta
      property="og:image"
      content={`${config.site.base_url}${image ? image : config.metadata.meta_image}`}
    />

    <!-- twitter tags -->
    <meta
      name="twitter:title"
      content={plainify(
        meta_title ? meta_title : title ? title : config.site.title,
      )}
    />
    <meta
      name="twitter:description"
      content={plainify(
        description ? description : config.metadata.meta_description,
      )}
    />
    <meta
      name="twitter:image"
      content={`${config.site.base_url}${image ? image : config.metadata.meta_image}`}
    />
    <meta name="twitter:card" content="summary_large_image" />

    <!-- Theme initialization script (prevents FOUC) -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme") || "system";
        let resolved = stored;
        if (stored === "system") {
          resolved = window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light";
        }
        document.documentElement.classList.add(resolved);
      })();
    </script>
  </head>
  <body class="font-primary text-base">
    <ScrollToTop client:load />
    <Header client:load pathname={Astro.url.pathname} />
    <SearchModal client:load />
    <main>
      <slot />
    </main>
    <Footer client:load />
    <ToasterWrapper client:load />
  </body>
</html>
